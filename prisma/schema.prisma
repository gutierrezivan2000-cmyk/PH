generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth Models (NextAuth.js v5)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Profile fields
  cargo         String?
  phone         String?
  company       String?
  city          String?
  onboarded     Boolean   @default(false)

  accounts     Account[]
  sessions     Session[]
  subscription Subscription?
  properties   Property[]
  generations  Generation[]
  usageRecords UsageRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Subscription (ePayco)
// ============================================

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  epaycoCustomerId    String?   @unique
  epaycoSubscriptionId String?  @unique
  epaycoRef           String?   // Last transaction reference
  planId              String?   // ePayco plan ID
  status              String    @default("inactive") // active, inactive, canceled, past_due
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Property Management
// ============================================

model Property {
  id      String  @id @default(cuid())
  userId  String
  name    String
  address String?
  city    String?
  units   Int?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations Generation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// AI Generation Jobs
// ============================================

model Generation {
  id         String  @id @default(cuid())
  userId     String
  propertyId String
  type       String
  status     String  @default("pending")
  progress   Int     @default(0) // 0-100 percentage
  month      Int
  year       Int

  inputFiles   Json
  inputText    String? @db.Text
  outputFiles  Json?
  tokensUsed   Int     @default(0)
  costUsd      Float   @default(0)
  errorMessage String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  completedAt DateTime?
}

// ============================================
// Usage Tracking
// ============================================

model UsageRecord {
  id      String   @id @default(cuid())
  userId  String
  date    DateTime @default(now())
  tokens  Int
  costUsd Float
  type    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
