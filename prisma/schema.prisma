generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Auth Models (NextAuth.js v5)
// ============================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?

  // Profile fields
  cargo         String?
  phone         String?
  company       String?
  city          String?
  onboarded     Boolean   @default(false)

  // Document branding (shown on generated informes/actas)
  logoUrl       String?
  brandColor    String?

  // Admin role
  role          String    @default("user") // "user" | "admin"

  // Moderation — banned users cannot log in and active sessions are revoked.
  banned        Boolean   @default(false)
  bannedAt      DateTime?
  banReason     String?

  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  properties    Property[]
  generations   Generation[]
  usageRecords  UsageRecord[]
  agentChats    AgentChat[]
  agentMemories AgentMemory[]
  tickets       Ticket[]
  adminActions  AdminAuditLog[] @relation("AdminActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// Subscription (ePayco)
// ============================================

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  epaycoCustomerId    String?   @unique
  epaycoSubscriptionId String?  @unique
  epaycoRef           String?   // Last transaction reference
  planId              String?   // ePayco plan ID
  status              String    @default("inactive") // active, inactive, canceled, past_due
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?

  // Add-on agents activated for this user (e.g. ["metra","hermes"])
  addonAgents         String[]  @default([])

  // Admin notes (free-form, used by support)
  adminNotes          String?   @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// Billing — pending checkout orders (payment integrity)
// ============================================

// A checkout order we created server-side BEFORE sending the user to ePayco.
// The confirmation callback resolves userId + plan + expected amount from HERE
// (keyed by the invoice ref), never from the unsigned x_extra fields — so a
// tampered callback can't upgrade a plan, activate someone else's account, or
// replay to renew for free.
model PendingOrder {
  id          String    @id @default(cuid())
  ref         String    @unique // the invoice we send to ePayco (ph-<userId>-<ts>)
  userId      String
  planType    String    // "pro" | "business" | "elite"
  amount      Int       // expected charge amount (COP)
  currency    String    @default("cop")
  status      String    @default("pending") // "pending" | "completed" | "rejected"
  epaycoRef   String? // x_ref_payco once ePayco confirms
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
}

// ============================================
// Rate limiting (fixed-window counters)
// ============================================

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "register:ip:1.2.3.4" or "register:email:x@y.com"
  count       Int      @default(0)
  windowStart DateTime @default(now())

  @@index([windowStart])
}

// ============================================
// Property Management
// ============================================

model Property {
  id         String  @id @default(cuid())
  userId     String
  name       String
  address    String?
  city       String?
  units      Int?

  // Building profile for the compliance calendar:
  // { ascensor, piscina, plantaElectrica, gimnasio, empleadosDirectos: boolean,
  //   polizaVence: "YYYY-MM-DD" | null }
  features   Json?

  // Admin's WhatsApp contact for residents of this property (shown in the portal).
  whatsapp   String?
  // Optional label to group/organize properties in the enterprise portfolio
  // (e.g. a zone, building type, or assigned administrator).
  groupLabel String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  generations   Generation[]
  documents     PropertyDocument[]
  monthlyData   PropertyMonthlyData[]
  unitList      Unit[]
  announcements Announcement[]
  certificates  Certificate[]
  assemblies    Assembly[]
  budgets       Budget[]
  ledgerEntries LedgerEntry[]
  pqrs          Pqrs[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================
// Enterprise batch: per-property monthly input staging
// ============================================

// A property's staged inputs for a given month — uploaded throughout the month
// so that "generate in batch" can pull each property's own complete data. One
// bucket per (property, month, year).
model PropertyMonthlyData {
  id             String   @id @default(cuid())
  propertyId     String
  userId         String
  month          Int
  year           Int
  files          Json     @default("[]") // [{name,url,type,size}]
  additionalText String?  @db.Text

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, month, year])
  @@index([userId, year, month])
}

// ============================================
// AI Generation Jobs
// ============================================

model Generation {
  id         String  @id @default(cuid())
  userId     String
  propertyId String
  type       String
  status     String  @default("pending")
  progress   Int     @default(0) // 0-100 percentage
  month      Int
  year       Int
  // Set when this generation is part of an enterprise batch run.
  batchId    String?

  inputFiles   Json
  inputText    String? @db.Text
  outputFiles  Json?
  tokensUsed   Int     @default(0)
  costUsd      Float   @default(0)
  errorMessage String?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([batchId])
  @@index([userId, createdAt])
}

// A batch generation run over many properties (Elite enterprise feature).
model GenerationBatch {
  id          String    @id @default(cuid())
  userId      String
  month       Int
  year        Int
  docTypes    String[]  @default([]) // subset of ["informe","acta","pptx"]
  status      String    @default("processing") // "processing" | "completed"
  total       Int       @default(0)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
}

// ============================================
// Units & Announcements (Comunicados)
// ============================================

// A private unit (apto/casa/local) inside a property. v1: contact directory
// for comunicados. F2 extends it with coeficiente/cartera. F3 adds the
// tokenized resident portal ("la unidad es la cuenta").
model Unit {
  id           String  @id @default(cuid())
  propertyId   String
  userId       String
  label        String  // "Apto 502", "Casa 12", "Local 3"
  residentName String?
  email        String?
  phone        String?

  // Cartera (F2): coeficiente de copropiedad (%) y cuota de administración (COP/mes).
  coeficiente  Float?
  monthlyFee   Int?

  // F3: unguessable public token for the account-less resident portal (/u/<token>).
  portalToken  String?  @unique

  property Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  charges  Charge[]
  payments UnitPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
}

// A billed amount against a unit (cuota mensual, extraordinaria, interés…).
// paidAmount is denormalized from FIFO payment allocation for cheap
// status/aging queries; the unit balance is always sum(charges) - sum(payments).
model Charge {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  unitId     String
  concept    String
  type       String   @default("admin") // "admin" | "extraordinaria" | "interes" | "otro"
  amount     Int // COP
  paidAmount Int      @default(0) // COP applied via FIFO
  month      Int?
  year       Int?
  dueDate    DateTime

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([unitId])
  @@index([userId])
}

// A payment received from a unit (manual registration in F2; online in F3).
// allocations: [{ chargeId, amount }] — lets a deleted payment reverse its
// FIFO application exactly.
model UnitPayment {
  id          String   @id @default(cuid())
  userId      String
  propertyId  String
  unitId      String
  amount      Int // COP
  method      String   @default("transferencia") // "efectivo" | "transferencia" | "consignacion" | "otro"
  reference   String?
  note        String?
  allocations Json     @default("[]")
  receivedAt  DateTime @default(now())

  unit Unit @relation(fields: [unitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([unitId])
  @@index([userId])
}

model Announcement {
  id             String    @id @default(cuid())
  userId         String
  propertyId     String
  subject        String
  content        String    @db.Text
  status         String    @default("sent") // "sent" | future: "draft" | "scheduled"
  recipientCount Int       @default(0)
  sentAt         DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([userId])
}

// ============================================
// PQRS del residente (F3.2) — sin cuenta, desde el portal
// ============================================

// Petición / Queja / Reclamo / Sugerencia radicada por un residente desde el
// portal. userId is the admin owner (denormalized for inbox queries).
model Pqrs {
  id              String   @id @default(cuid())
  userId          String
  propertyId      String
  unitId          String?
  code            String   @unique // radicado, ej "PQR-7F3K2Q"
  type            String   @default("peticion") // peticion | queja | reclamo | sugerencia
  subject         String
  status          String   @default("radicado") // radicado | en_proceso | resuelto | cerrado
  residentName    String?
  residentContact String? // email o teléfono que dejó el residente
  unitLabel       String? // snapshot for display

  property Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  messages PqrsMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([status])
}

model PqrsMessage {
  id        String   @id @default(cuid())
  pqrsId    String
  fromAdmin Boolean  @default(false)
  content   String   @db.Text

  pqrs Pqrs @relation(fields: [pqrsId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([pqrsId])
}

// ============================================
// Presupuesto y ejecución (F2.3)
// ============================================

// One budget per (property, year). items is the chart of budgeted lines:
// [{ id, concept, group: "ingreso"|"gasto", budgeted: int COP }].
model Budget {
  id         String @id @default(cuid())
  userId     String
  propertyId String
  year       Int
  items      Json   @default("[]")

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, year])
  @@index([userId])
}

// An actual income/expense movement (ejecución). itemId links to a budget
// line so execution can be compared rubro by rubro; type separates ordinary
// movements from imprevistos-fund contributions/withdrawals.
model LedgerEntry {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  date       DateTime
  concept    String
  itemId     String? // budget item id (rubro), null for unclassified
  type       String   @default("gasto") // "ingreso" | "gasto" | "fondo_aporte" | "fondo_retiro"
  amount     Int
  note       String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
  @@index([userId])
}

// ============================================
// Assemblies (Convocatoria + control de términos Ley 675)
// ============================================

model Assembly {
  id         String    @id @default(cuid())
  userId     String
  propertyId String
  type       String    // "ordinaria" | "extraordinaria"
  date       DateTime  // fecha y hora de la asamblea
  modality   String    @default("presencial") // "presencial" | "virtual" | "mixta"
  location   String? // lugar físico o enlace de la reunión
  agenda     Json      @default("[]") // string[] — orden del día
  status     String    @default("convocada") // "convocada" | "realizada" | "cancelada"
  convokedAt DateTime? // cuándo se envió/emitió la convocatoria
  actaReadyAt DateTime? // cuándo se publicó el acta (cierra el término de 20 días hábiles)

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
}

// ============================================
// Certificates (Paz y salvo / Certificado de residencia) with public QR verify
// ============================================

model Certificate {
  id            String    @id @default(cuid())
  userId        String
  propertyId    String
  unitId        String?
  type          String    // "paz_y_salvo" | "residencia"
  recipientName String
  unitLabel     String
  // { recipientDocument?, validUntil? ("YYYY-MM-DD"), residesSince?, note? }
  meta          Json?
  verifyCode    String    @unique // unguessable public verification token
  status        String    @default("valid") // "valid" | "revoked"
  revokedAt     DateTime?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([propertyId])
}

// ============================================
// Compliance calendar (Calendario de cumplimiento)
// ============================================

// One row per acted-on auto item (done/dismissed) OR per custom item.
// Auto items are computed from rules (src/lib/compliance.ts) + Property.features;
// their row exists only once the admin marks them.
model ComplianceRecord {
  id          String    @id @default(cuid())
  userId      String
  propertyId  String
  itemKey     String    // stable rule key ("asamblea-2026") or the cuid for custom items
  source      String    @default("auto") // "auto" | "custom"
  title       String?   // custom items only
  description String?   @db.Text
  dueDate     DateTime? // custom items only
  status      String    @default("done") // "pending" (custom) | "done" | "dismissed"
  doneAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, itemKey])
  @@index([userId])
  @@index([propertyId])
}

// ============================================
// Property Documents (Manual de convivencia, Reglamento)
// ============================================

model PropertyDocument {
  id         String   @id @default(cuid())
  propertyId String
  type       String   // "manual_convivencia" | "reglamento_interno" | "otro"
  name       String
  url        String
  size       Int      @default(0)
  mimeType   String?
  // Cached extracted text for the resident reglamento assistant (F3.2b).
  extractedText String? @db.Text

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([propertyId])
}

// ============================================
// AI Agents — Chats, Messages & Memories
// ============================================

model AgentChat {
  id       String @id @default(cuid())
  userId   String
  agentId  String // "themis" | "chronos" | "metra" | "nomethes" | "hermes" | "logistes"
  title    String @default("Nueva conversacion")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, agentId])
}

model AgentMessage {
  id     String @id @default(cuid())
  chatId String
  role   String // "user" | "assistant"
  content String @db.Text
  attachments Json? // [{name, url, type, size}]

  chat AgentChat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([chatId])
}

model AgentMemory {
  id      String @id @default(cuid())
  userId  String
  agentId String
  content String @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, agentId])
}

// ============================================
// Usage Tracking
// ============================================

model UsageRecord {
  id      String   @id @default(cuid())
  userId  String
  date    DateTime @default(now())
  tokens  Int
  costUsd Float
  type    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ============================================
// Support Tickets
// ============================================

model Ticket {
  id          String   @id @default(cuid())
  userId      String
  subject     String
  category    String   @default("general") // "general" | "billing" | "technical" | "feature" | "bug"
  priority    String   @default("normal")  // "low" | "normal" | "high" | "urgent"
  status      String   @default("open")    // "open" | "pending" | "resolved" | "closed"
  assignedTo  String?  // Admin userId who picked it up

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([assignedTo])
}

model TicketMessage {
  id        String  @id @default(cuid())
  ticketId  String
  fromAdmin Boolean @default(false) // false = from user, true = from admin/support
  authorId  String  // userId who wrote it (admin or user)
  content   String  @db.Text
  attachments Json? // [{name, url, size}]
  internal  Boolean @default(false) // internal admin-only notes not shown to user

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ============================================
// Admin Audit Log
// ============================================

model AdminAuditLog {
  id        String   @id @default(cuid())
  adminId   String   // userId of admin who did the action
  action    String   // "subscription.cancel" | "addon.activate" | "ticket.resolve" | etc.
  targetType String? // "user" | "subscription" | "ticket"
  targetId  String?
  metadata  Json?    // any extra context (before/after values etc.)
  ipAddress String?

  admin User @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}
