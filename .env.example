# ============================================
# PH Gestión — Environment Variables
# Copy this to .env and fill in the values
# ============================================

# Demo Mode (set to "false" for production)
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://your-domain.com"

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host-unpooled/dbname?sslmode=require"

# ePayco
EPAYCO_PUBLIC_KEY=""
EPAYCO_PRIVATE_KEY=""
EPAYCO_P_CUST_ID=""
EPAYCO_P_KEY=""
EPAYCO_TEST="true"

# Claude / Anthropic API
ANTHROPIC_API_KEY=""

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Support — WhatsApp escalation link (used by chatbot and Configuracion page)
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL="https://wa.me/573001112233"

# Support chatbot model (OpenAI). Defaults to gpt-4.1-nano.
SUPPORT_CHAT_MODEL="gpt-4.1-nano"

# ============================================
# Admin Console (admin subdomain)
# ============================================

# Comma-separated emails auto-promoted to admin on login (permanent admins).
# Runtime: takes effect on the next login, no redeploy needed.
# See docs/ADMIN_SETUP.md for the full flow.
ADMIN_EMAILS="tu-correo-de-login@dominio.com"

# Set to "true" to reach the admin panel at <main-host>/admin without a
# dedicated admin subdomain (still gated by requireAdmin). Redeploy after
# changing. Leave unset to keep admin on its own "admin." subdomain only.
# ALLOW_ADMIN_ON_MAIN_HOST="true"

# OPTIONAL. Only needed if the admin console lives on a host that does NOT start
# with "admin." — any "admin.*" host is auto-detected without this var. Must be
# a SEPARATE host from the main app (do NOT set it to your main domain).
# Build-time (NEXT_PUBLIC_): changing it requires a redeploy.
# NEXT_PUBLIC_ADMIN_HOSTNAME="admin.your-domain.com"

# OPTIONAL. Share the session across app+admin subdomains. Must start with a
# dot. Build-time: requires a redeploy. Leave unset to log in separately on the
# admin subdomain.
# COOKIE_DOMAIN=".your-domain.com"

# Dedicated secret for POST /api/admin/migrate (raw DDL runner).
# Generate with: openssl rand -base64 32  — never reuse AUTH_SECRET.
ADMIN_MIGRATE_SECRET=""
