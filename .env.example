# ============================================
# PH Gestión — Environment Variables
# Copy this to .env and fill in the values
# ============================================

# Demo Mode (set to "false" for production)
DEMO_MODE=true
NEXT_PUBLIC_DEMO_MODE=true

# Auth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://your-domain.com"

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host-unpooled/dbname?sslmode=require"

# ePayco
EPAYCO_PUBLIC_KEY=""
EPAYCO_PRIVATE_KEY=""
EPAYCO_P_CUST_ID=""
EPAYCO_P_KEY=""
EPAYCO_TEST="true"

# Claude / Anthropic API
ANTHROPIC_API_KEY=""

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# App URL
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Support — WhatsApp escalation link (used by chatbot and Configuracion page)
NEXT_PUBLIC_WHATSAPP_SUPPORT_URL="https://wa.me/573001112233"

# Support chatbot model (OpenAI). Defaults to gpt-4.1-nano.
SUPPORT_CHAT_MODEL="gpt-4.1-nano"

# ============================================
# Admin Console (admin subdomain)
# ============================================

# Comma-separated emails auto-promoted to admin on login (permanent admins).
ADMIN_EMAILS="tu-correo@dominio.com"

# Hostname that serves the admin console (middleware rewrites it to /admin/*).
NEXT_PUBLIC_ADMIN_HOSTNAME="management.your-domain.com"

# Cookie domain so the session is shared between the app and admin subdomains.
# MUST start with a dot, e.g. ".your-domain.com".
COOKIE_DOMAIN=".your-domain.com"

# Dedicated secret for POST /api/admin/migrate (raw DDL runner).
# Generate with: openssl rand -base64 32  — never reuse AUTH_SECRET.
ADMIN_MIGRATE_SECRET=""
